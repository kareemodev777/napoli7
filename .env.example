# Napoli7 environment variables.
# Copy to .env.local for local dev and set the real values. NEVER commit secrets.
# On Netlify, set these in the site's environment (Production + Deploy Preview).
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser — keep secrets unprefixed.

# Deployed origin. Used for Stripe success/cancel URLs and canonical links.
#   local:      http://localhost:3000
#   production: https://napoli7.netlify.app   (or the final custom domain)
NEXT_PUBLIC_SITE_URL=

# Stripe (use test keys locally, live keys only once approved for live AED payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From `stripe listen` locally, or the dashboard webhook endpoint in production.
STRIPE_WEBHOOK_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phone / SMS OTP login (Twilio):
# The SMS OTP login flow is built into the app (login page → "Log in with an SMS
# code"). It uses Supabase Auth's Phone provider, so the Twilio credentials are
# NOT set here — enter them in the Supabase dashboard:
#   Authentication → Providers → Phone → enable, choose Twilio, then set:
#     Twilio Account SID, Twilio Auth Token, Twilio Message Service SID.
# No app env var is required; the code (signInWithOtp / verifyOtp) is provider-agnostic.

# Resend (order/kitchen emails). Omit to fall back to console logging in dev.
RESEND_API_KEY=
ORDER_EMAIL_TO=info@napoli7.com
ORDER_EMAIL_FROM=orders@napoli7.com

# WhatsApp Cloud API (kitchen alerts, customer status, rider briefs).
# Omit to disable WhatsApp — the phone notifications then fall back to SMS below.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
KITCHEN_WHATSAPP_NUMBER=

# Outbound SMS (Twilio Messages API) — customer status updates and rider briefs.
#
# This is SEPARATE from the Twilio Verify setup above. Verify only sends login
# OTPs; it CANNOT send a notification, and it gives you nothing to send one FROM.
# Without the sender below, no SMS is sent at all — however well Verify works.
#
# TWILIO_MESSAGING_SERVICE_SID (MG…) is the one to set: the UAE requires a
# registered sender ID, and the Messaging Service is what holds it. A bare
# TWILIO_SMS_FROM number works for testing but may not deliver to UAE handsets.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SMS_FROM=

# POS integration (xtbooks). Pushes confirmed website orders into the POS.
# Leave POS_PUSH_ENABLED unset/false to disable entirely (no calls made).
# HAS_POS requires BOTH a URL and POS_PUSH_ENABLED=true, so it stays inert in
# dev/preview until explicitly switched on.
POS_PUSH_ENABLED=
# Order-create endpoint (WooCommerce-compatible):
POS_WEBHOOK_URL=https://xtbooks.app/pos/napoli-pizza/public/api/woocommerce/webhook
# Product / order-update endpoint (note the double slash is as provided by POS):
POS_PRODUCT_WEBHOOK_URL=https://xtbooks.app/pos/napoli-pizza/public/api//woocommerce/product-webhook
# Auth — exact header/scheme TBD with POS provider. Sent as Bearer + X-API-Key
# when set; leave empty if the POS needs no auth.
POS_API_KEY=
# Optional: override the auth header name if the POS expects a custom one.
POS_AUTH_HEADER=
